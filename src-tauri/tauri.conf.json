{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalTranslate",
  "version": "0.5.0",
  "identifier": "com.localtranslate.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1454",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LocalTranslate",
        "width": 1100,
        "height": 740,
        "minWidth": 720,
        "minHeight": 520
      },
      {
        "label": "quick",
        "title": "LocalTranslate — tradução rápida",
        "url": "quick.html",
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "width": 560,
        "height": 360,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
